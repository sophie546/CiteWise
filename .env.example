# =============================================
# Root .env.example — copy to api/.env and web/.env with real values
# =============================================

# ---- api/.env ----

PORT=8081

# CATalyst Supabase (service role — server only, NEVER expose to browser)
SUPABASE_URL=https://sdtkvjedqygqyudwirsf.supabase.co
SUPABASE_KEY=<supabase_service_role_key>
SUPABASE_SERVICE_ROLE_KEY=<supabase_service_role_key>

FRONTEND_URL=http://localhost:5173

# CATalyst n8n webhooks (localhost:5678)
N8N_BASE_URL=http://localhost:5678
N8N_EXTRACTOR_WEBHOOK=http://localhost:5678/webhook/fc7ac6b7-4546-4656-8657-54ec312e5077
N8N_SUMMARIZER_PROD_WEBHOOK_URL=http://localhost:5678/webhook/a4a78b18-19b7-4ad2-9754-60b5dcfb71d0
N8N_GAPEXTRACTOR_PROD_WEBHOOK_URL=http://localhost:5678/webhook/c88ffe20-1055-4ad7-abcc-1b966b5a757a
N8N_TOPIC_PROD_WEBHOOK_URL=http://localhost:5678/webhook/83404315-871e-4029-b981-951e1f4ea9ed

# CiteWise n8n webhooks (same n8n instance, localhost:5678)
CITEWISE_N8N_SCORING_WEBHOOK_URL=http://localhost:5678/webhook/semantic_scoring
CITEWISE_N8N_SYNTHESIS_WEBHOOK_URL=http://localhost:5678/webhook/citewise-synthesizer-v2
CITEWISE_N8N_CONNECT_TIMEOUT_MS=5000
CITEWISE_N8N_READ_TIMEOUT_MS=120000

# CiteWise scoring limits (defaults below match the original Spring Boot config)
CITEWISE_SCORING_MAX_CHARS_TO_N8N=9000
CITEWISE_SCORING_MAX_CHUNKS=6
CITEWISE_SCORING_CHUNK_SIZE=1000
CITEWISE_SCORING_CHUNK_OVERLAP=100


# ---- web/.env ----

VITE_SUPABASE_URL=https://sdtkvjedqygqyudwirsf.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase_anon_key>
VITE_API_BASE_URL=http://localhost:8081/api
